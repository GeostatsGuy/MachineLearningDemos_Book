q = np.array([1.0, 0.0])                                      # query vector 

key_angles_deg = np.array([5, 45, 90, 135,180])               # keys 1 - 5
key_angles_rad = np.deg2rad(key_angles_deg)
keys = np.vstack([np.cos(key_angles_rad), np.sin(key_angles_rad)]).T

angles_deg = np.linspace(0, 180, 400)
angles_rad = np.deg2rad(angles_deg)
vecs = np.vstack([np.cos(angles_rad), np.sin(angles_rad)]).T

dot_vals = vecs @ q                                           # similarity measures
l2_vals = -1.0*np.linalg.norm(vecs - q, axis=1)

fig, axes = plt.subplots(1, 3, figsize=(5, 15))               # plot query and keys are vectors

ax = axes[0]
ax.set_title(r"Query and Keys ($d=2$ Vectors)")
ax.quiver(0, 0, q[0], q[1],                                   # query vector
          angles='xy', scale_units='xy', scale=1,
          color='red', width=0.006)
ax.scatter([1],[0],color='salmon',edgecolor='black',s=200,zorder=30)
ax.text(1,-0.01,"Q",ha='center',va='center',color='black',fontsize=8,zorder=30)
ax.text(1.06, -0.1, "(1,0)", color='black', fontsize=8,zorder=40)

for i, (ang, k) in enumerate(zip(key_angles_deg, keys), start=1): # keys
    ax.quiver(0, 0, k[0], k[1],angles='xy', scale_units='xy', scale=1,color='#BF5700', width=0.004)
    ax.scatter(k[0],k[1],color='orange',edgecolor='black',s=200,zorder=20)
    ax.text(k[0]+0.45,k[1],'('+ str(np.round(k[0],2)) + ', ' + str(np.round(k[1],2)) + ')',ha='center',va='center',fontsize=8,zorder=40)
    ax.text(k[0],k[1],f'$K_{i}$',ha='center',va='center',fontsize=8,zorder=40)
    ax.text(k[0]+0.40,k[1]-0.08,rf'$\alpha$={ang:.1f}',ha='center',va='center',fontsize=8)

ax.set_xlim(-1.8, 1.8); ax.set_ylim(-0.8, 1.8); ax.set_box_aspect(1)
ax.set_xlabel(r'$d_1$'); ax.set_ylabel(r'$d_2$'); add_grid2(ax)

ax = axes[1]                                                  # L2 vs. angle
ax.set_title("L2 Distance vs Angle")
ax.plot(angles_deg, l2_vals, color='#BF5700',linewidth=2); ax.set_box_aspect(1)
ax.set_xlabel("Angle (degrees)"); ax.set_ylabel("-L2 Distance"); add_grid2(ax)
ax.axhline(0, color='black', linewidth=0.8); ax.set_ylim([-2.2,0.1])

for i, ang in enumerate(key_angles_deg, start=1):             # key markers
