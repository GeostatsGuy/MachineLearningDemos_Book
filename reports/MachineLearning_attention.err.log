    y = -1.0*np.linalg.norm(k - q)
    ax.scatter(ang, y+0.03, color='orange',edgecolor='black',alpha=1.0,s=200,zorder=10)
    ax.text(ang, y + 0.0, f"K{i}", ha='center',size=8,color='black',zorder=20)
    ax.axvline(ang, color='black', linestyle='--', alpha=0.3)

ax = axes[2]                                                  # dot product vs. angle
ax.set_title("Dot Product vs Angle")
ax.plot(angles_deg, dot_vals, color='#BF5700',linewidth=2); ax.set_box_aspect(1)
ax.set_xlabel("Angle (degrees)"); ax.set_ylabel("Dot product"); add_grid2(ax)
ax.axhline(0, color='black', linewidth=0.8); ax.set_ylim([-1.2,1.2])

for i, ang in enumerate(key_angles_deg, start=1):             # key markers
